`timescale 1ns/1ps

//============================================================
// File        : TB_Power_Controller.v
// Testbench   : TB_Power_Controller
// Description : Final TB for Power_Controller
//
// Checks:
//   1. oClkEn starts HIGH after reset.
//   2. iInValid activity keeps clock enabled.
//   3. After 10 idle cycles, oClkEn goes LOW.
//   4. No extra rising edge appears on oGatedFastClk after oClkEn LOW.
//   5. New iInValid wakes the clock again.
//============================================================

module TB_Power_Controller;

    localparam integer IDLE_TIMEOUT_TB = 10;

    reg  iFastClk;
    reg  iResetN;
    reg  iInValid;

    wire oClkEn;
    wire oGatedFastClk;

    integer gated_edges_before;
    integer gated_edges_after;

    //--------------------------------------------------------
    // DUT
    //--------------------------------------------------------
    Power_Controller
    #(
        .IDLE_TIMEOUT (IDLE_TIMEOUT_TB),
        .SIM_MODE     (0)
    )
    dut
    (
        .iFastClk      (iFastClk),
        .iResetN       (iResetN),
        .iInValid      (iInValid),
        .oClkEn        (oClkEn),
        .oGatedFastClk (oGatedFastClk)
    );

    //--------------------------------------------------------
    // 100 MHz fast clock
    // Period = 10 ns
    //--------------------------------------------------------
    initial begin
        iFastClk = 1'b0;
        forever #5 iFastClk = ~iFastClk;
    end

    //--------------------------------------------------------
    // Count gated clock rising edges
    //--------------------------------------------------------
    always @(posedge oGatedFastClk) begin
        if (iResetN)
            gated_edges_after = gated_edges_after + 1;
    end

    //--------------------------------------------------------
    // Main stimulus
    //--------------------------------------------------------
    initial begin
        $dumpfile("TB_Power_Controller.vcd");
        $dumpvars(0, TB_Power_Controller);

        iResetN = 1'b0;
        iInValid = 1'b0;

        gated_edges_before = 0;
        gated_edges_after  = 0;

        //----------------------------------------------------
        // Reset
        //----------------------------------------------------
        repeat (5) @(posedge iFastClk);
        iResetN = 1'b1;

        repeat (2) @(posedge iFastClk);

        if (oClkEn !== 1'b1)
            $display("ERROR: oClkEn should be HIGH after reset.");
        else
            $display("PASS : oClkEn HIGH after reset.");

        //----------------------------------------------------
        // Activity phase
        //----------------------------------------------------
        repeat (4) begin
            @(posedge iFastClk);
            iInValid = 1'b1;
        end

        @(posedge iFastClk);
        iInValid = 1'b0;

        $display("INFO : iInValid stopped at time %0t", $time);

        //----------------------------------------------------
        // Wait for shutdown
        //----------------------------------------------------
        wait (oClkEn == 1'b0);
        #1;

        if (oClkEn !== 1'b0)
            $display("ERROR: oClkEn did not go LOW.");
        else
            $display("PASS : oClkEn went LOW after idle timeout.");

        //----------------------------------------------------
        // Check that no gated clock edges pass after disable
        //----------------------------------------------------
        gated_edges_before = gated_edges_after;

        repeat (6) @(posedge iFastClk);
        #1;

        if (gated_edges_after != gated_edges_before)
            $display("ERROR: Extra gated clock edge detected after oClkEn LOW.");
        else
            $display("PASS : No extra gated clock edge after oClkEn LOW.");

        //----------------------------------------------------
        // Wake-up phase
        //----------------------------------------------------
        @(posedge iFastClk);
        iInValid = 1'b1;

        repeat (2) @(posedge iFastClk);
        #1;

        if (oClkEn !== 1'b1)
            $display("ERROR: oClkEn did not return HIGH after iInValid.");
        else
            $display("PASS : oClkEn returned HIGH after iInValid.");

        //----------------------------------------------------
        // Stop activity again
        //----------------------------------------------------
        @(posedge iFastClk);
        iInValid = 1'b0;

        wait (oClkEn == 1'b0);
        #1;

        if (oClkEn !== 1'b0)
            $display("ERROR: oClkEn did not go LOW in second idle phase.");
        else
            $display("PASS : oClkEn LOW in second idle phase.");

        repeat (10) @(posedge iFastClk);

        $display("Power_Controller final testbench finished.");
        $finish;
    end

endmodule